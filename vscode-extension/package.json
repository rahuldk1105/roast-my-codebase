{
  "name": "roast-my-codebase",
  "displayName": "Roast My Codebase",
  "description": "Get roasted. Get better. Ship faster.",
  "version": "0.1.0",
  "publisher": "roast-my-codebase",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "code quality",
    "linter",
    "analysis",
    "health",
    "roast"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "roast.scanWorkspace",
        "title": "Roast: Scan Workspace",
        "icon": "$(flame)"
      },
      {
        "command": "roast.scanFile",
        "title": "Roast: Scan Current File",
        "icon": "$(flame)"
      },
      {
        "command": "roast.showReport",
        "title": "Roast: Show Report",
        "icon": "$(graph)"
      },
      {
        "command": "roast.generateBadge",
        "title": "Roast: Generate Badge",
        "icon": "$(shield)"
      },
      {
        "command": "roast.clearCache",
        "title": "Roast: Clear Cache",
        "icon": "$(trash)"
      }
    ],
    "configuration": {
      "title": "Roast My Codebase",
      "properties": {
        "roast.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable roast-my-codebase analysis"
        },
        "roast.scanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan files on save"
        },
        "roast.scanOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan workspace on open"
        },
        "roast.showInlineWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show findings as inline diagnostics"
        },
        "roast.statusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show health score in status bar"
        },
        "roast.cliPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to roast-my-codebase CLI (leave empty to use global)"
        },
        "roast.threshold": {
          "type": "number",
          "default": 70,
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum health score threshold"
        },
        "roast.disabledScanners": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of scanner names to disable"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "roast-explorer",
          "title": "Roast My Codebase",
          "icon": "resources/flame.svg"
        }
      ]
    },
    "views": {
      "roast-explorer": [
        {
          "id": "roast.findingsView",
          "name": "Findings",
          "icon": "resources/flame.svg"
        },
        {
          "id": "roast.statsView",
          "name": "Statistics",
          "icon": "resources/graph.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "execa": "^8.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/roast-my-codebase.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/roast-my-codebase/issues"
  },
  "license": "MIT"
}
