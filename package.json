{
  "name": "roast-my-codebase",
  "version": "1.3.0",
  "description": "Get roasted. Get better. Ship faster. A CLI that analyzes your codebase and delivers brutally honest (but funny) feedback.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "roast-my-codebase": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings 60",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "codebase",
    "code-quality",
    "roast",
    "analysis",
    "lint",
    "developer-tools",
    "dx",
    "typescript",
    "health-check"
  ],
  "author": "rahuldk <rahuldk1105@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahuldk1105/roast-my-codebase"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@inquirer/prompts": "^8.5.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chalk-animation": "^2.0.3",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/node": "^26.0.1",
    "@types/picomatch": "^4.0.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-plugin-security": "^4.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
